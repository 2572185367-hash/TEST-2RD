{
  "name": "paper-keyword-search",
  "version": "1.0.0",
  "description": "论文关键词检索 - 基于Dify API的智能论文检索工具",
  "main": "server.js",
  "scripts": {
    "server": "node server.js",
    "client": "cd client && npm run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "cd client && npm run build",
    "start": "node server.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
